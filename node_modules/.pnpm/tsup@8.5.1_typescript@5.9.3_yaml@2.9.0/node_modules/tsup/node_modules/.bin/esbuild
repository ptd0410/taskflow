#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/macbook/WorkSpace/taskflow/node_modules/.pnpm/esbuild@0.27.7/node_modules/esbuild/node_modules:/Users/macbook/WorkSpace/taskflow/node_modules/.pnpm/esbuild@0.27.7/node_modules:/Users/macbook/WorkSpace/taskflow/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/macbook/WorkSpace/taskflow/node_modules/.pnpm/esbuild@0.27.7/node_modules/esbuild/node_modules:/Users/macbook/WorkSpace/taskflow/node_modules/.pnpm/esbuild@0.27.7/node_modules:/Users/macbook/WorkSpace/taskflow/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
exec "$basedir/../../../esbuild/bin/esbuild"   "$@"
exit $?
